// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Service {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  description String
  basePrice   Float
  category    String    // Residential, Enterprise
  bookings    Booking[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model StateLocation {
  id        String    @id @default(cuid())
  code      String    @unique // NSW, VIC, etc.
  name      String
  isActive  Boolean   @default(true)
  bookings  Booking[]
}

model Booking {
  id           String   @id @default(cuid())
  facilityName String
  sqft         Int
  date         DateTime
  status       String   @default("PENDING")
  service      Service  @relation(fields: [serviceId], references: [id])
  serviceId    String
  state        StateLocation @relation(fields: [stateCode], references: [code])
  stateCode    String
  enterpriseClient EnterpriseClient? @relation(fields: [enterpriseClientId], references: [id])
  enterpriseClientId String?
  mythosData   String    // Store the 2026 specific metadata (Karpathy Pattern)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model EnterpriseClient {
  id          String    @id @default(cuid())
  name        String
  type        String    // NDIS, REAL_ESTATE, BUSINESS
  contactInfo String
  apiId       String?   @unique
  bookings    Booking[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  details   String
  timestamp DateTime @default(now())
}

model Flashcard {
  id          String   @id @default(cuid())
  title       String
  content     String
  icon        String   // Lucide icon name
  category    String   // Presets: Compliance, Efficiency, Technology
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SiteConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model AdminUser {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String
  passwordHash String  // In production, use proper hashing (bcrypt)
  role        String   @default("admin") // admin, editor, viewer
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PageContent {
  id          String   @id @default(cuid())
  page        String   // "home", "services", "pricing", "booking", "compliance", etc.
  section     String   // "hero", "quote", "enterprise", "footer", etc.
  key         String   // "title", "subtitle", "description", "imageUrl", etc.
  value       String   
  locale      String   @default("en")
  updatedAt   DateTime @updatedAt

  @@unique([page, section, key, locale])
}

model Media {
  id          String   @id @default(cuid())
  url         String
  alt         String   @default("")
  type        String   // "image", "video", "icon", "logo"
  page        String   @default("") // which page uses it
  size        Int      @default(0) // bytes
  uploadedAt  DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AdCampaign {
  id          String   @id @default(cuid())
  name        String
  description String   @default("")
  imageUrl    String
  linkUrl     String   @default("")
  startDate   DateTime
  endDate     DateTime?
  budget      Float    @default(0)
  spent       Float    @default(0)
  impressions Int      @default(0)
  clicks      Int      @default(0)
  isActive    Boolean  @default(true)
  targetPages String    // which pages to show on
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AnalyticsConfig {
  id          String   @id @default(cuid())
  key         String   @unique // "gtmId", "gaId", "vercelEnabled", etc.
  value       String
  isActive    Boolean  @default(true)
  updatedAt   DateTime @updatedAt
}

model Testimonial {
  id          String   @id @default(cuid())
  name        String
  role        String   @default("customer")
  company     String   @default("")
  rating      Int      @default(5)
  content     String   
  imageUrl    String   @default("")
  isFeatured  Boolean  @default(false)
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
